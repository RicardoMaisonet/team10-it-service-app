<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Apex Valet Club</title>

<style>
:root {
  --bg:#050608;
  --panel:rgba(15,17,20,0.65);
  --text:#e5e7eb;
  --muted:#9ca3af;
  --accent:#c8a96a;
  --accent-soft:#f2d18f;
  --border:rgba(255,255,255,0.08);
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.6;
}

.container {
  max-width:1200px;
  margin:auto;
  padding:40px 20px;
}

/* ===== HEADER ===== */
.page-header {
  position:sticky;
  top:0;
  background:rgba(5,6,8,0.7);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  z-index:1000;
}

.header-inner {
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.brand {
  font-weight:600;
  font-size:18px;
}

.nav-links a {
  margin:0 10px;
  color:var(--muted);
  text-decoration:none;
}

/* BUTTONS */
.btn {
  padding:12px 26px;
  border-radius:999px;
  text-decoration:none;
  transition:.3s;
  display:inline-block;
}

.btn-primary {
  background:linear-gradient(135deg,var(--accent),var(--accent-soft));
  color:black;
  font-weight:600;
}

.btn-primary:hover {
  transform:translateY(-2px);
  box-shadow:0 10px 30px rgba(200,169,106,.35);
}

.btn-ghost {
  border:1px solid var(--border);
  color:white;
}

/* ===== HERO ===== */
.hero {
  background:url('https://images.unsplash.com/photo-1483721310020-03333e577078?auto=format&fit=crop&w=1400&q=80') center/cover;
  position:relative;
}

.hero::before {
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.7);
}

.hero::after {
  content:"";
  position:absolute;
  inset:0;
  background:radial-gradient(circle, rgba(200,169,106,.1), transparent 70%);
}

.hero-content {
  position:relative;
  text-align:center;
  padding:120px 20px;
}

.hero h1 {
  font-size:40px;
  max-width:700px;
  margin:auto;
}

.hero p {
  color:var(--muted);
  margin:20px auto;
  max-width:600px;
}

.hero .highlight {
  color:var(--accent);
  margin-top:10px;
}

/* ===== GLASS ===== */
.glass {
  background:var(--panel);
  backdrop-filter:blur(14px);
  border:1px solid var(--border);
  border-radius:20px;
  padding:30px;
}

/* ===== FORM ===== */
.contact {
  text-align:center;
}

.subtitle {
  color:var(--muted);
  margin-bottom:30px;
}

.lux-form {
  max-width:900px;
  margin:40px auto;
  background:rgba(10,12,15,.75);
  padding:40px;
  border-radius:20px;
  border:1px solid var(--border);
}

.form-grid {
  display:grid;
  gap:20px;
  grid-template-columns:repeat(2,1fr);
}

.input-group {
  text-align:left;
}

.input-group.full {
  grid-column:span 2;
}

label {
  font-size:12px;
  color:var(--muted);
}

input, select, textarea {
  width:100%;
  padding:12px;
  background:rgba(0,0,0,.4);
  border:1px solid var(--border);
  border-radius:10px;
  color:white;
}

input:focus, textarea:focus, select:focus {
  outline:none;
  border-color:var(--accent);
  box-shadow:0 0 0 1px var(--accent),0 0 20px rgba(200,169,106,.2);
}

textarea { height:120px }

.form-note {
  color:#6b7280;
  font-size:12px;
  margin:15px 0;
}

/* ===== REVEAL ===== */
.reveal {
  opacity:0;
  transform:translateY(40px);
  transition:.8s;
}

.reveal.show {
  opacity:1;
  transform:translateY(0);
}

/* MOBILE */
@media(max-width:768px){
  .form-grid { grid-template-columns:1fr; }
}
</style>
</head>

<body>

<header class="page-header">
  <div class="container header-inner">
    <div class="brand">Apex Valet Club</div>
    <nav class="nav-links">
      <a href="#contact">Apply</a>
    </nav>
    <a href="#contact" class="btn btn-primary">Apply for Membership</a>
  </div>
</header>

<section class="hero">
  <div class="hero-content">
